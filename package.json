{
  "name": "ai-company",
  "version": "1.0.0",
  "description": "Multi-agent AI coordination framework — global hub managing multiple isolated projects",
  "license": "MIT",
  "author": "CanCan",
  "repository": {
    "type": "git",
    "url": "https://github.com/Can-Can/AICompany.git"
  },
  "type": "module",
  "bin": {
    "ai-company": "bin/ai-company.js"
  },
  "files": [
    "bin/",
    "roles/*.md",
    "memories/",
    "templates/",
    "dashboard/"
  ],
  "scripts": {
    "test": "node --test test/**/*.test.js",
    "test:e2e": "cucumber-js --config test/e2e/cucumber.js",
    "test:all": "npm test && npm run test:e2e",
    "test:e2e:headed": "HEADED=true cucumber-js --config test/e2e/cucumber.js",
    "build:dashboard": "cd dashboard && npm run build",
    "dev:dashboard": "cd dashboard && npm run dev"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "chokidar": "^4.0.0",
    "express": "^4.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2"
  }
}
