#!/usr/bin/env bash
set -euo pipefail

COMPANY_BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$COMPANY_BIN_DIR/.." && pwd)"

source "$COMPANY_BIN_DIR/lib/parse-frontmatter.sh"

TASKS_DIR="$PROJECT_DIR/tasks"
PID_FILE="$TASKS_DIR/.server-pid"

usage() {
  cat <<EOF_USAGE
Usage: company <command> [args]

Commands:
  start                    Launch company-server (web dashboard on :4000)
  stop                     Stop the company-server
  health                   Show server health (PID, status)
  status                   Show dashboard of all roles and task counts
  tasks [role]             List all tasks, optionally filtered by role
  next-id                  Print the next sequential task ID
  create <to-role> <title> Create a new task from human
  send <role> "message"    Send a message to a waiting agent
EOF_USAGE
}

cmd_start() {
  local pid_file="$TASKS_DIR/.server-pid"
  if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
    echo "Server already running (PID $(cat "$pid_file")). Use 'company stop' first."
    exit 1
  fi

  echo "Starting AI Company server..."
  nohup node "$COMPANY_BIN_DIR/company-server.js" >> "$PROJECT_DIR/logs/server.log" 2>&1 &
  sleep 1
  if [ -f "$pid_file" ]; then
    echo "Server started (PID $(cat "$pid_file")). Dashboard: http://localhost:4000"
  else
    echo "ERROR: Server failed to start. Check logs/server.log"
    exit 1
  fi
}

cmd_stop() {
  local pid_file="$TASKS_DIR/.server-pid"
  if [ ! -f "$pid_file" ]; then
    echo "No server PID file found. Server may not be running."
    exit 1
  fi
  local pid
  pid="$(cat "$pid_file")"
  if kill -0 "$pid" 2>/dev/null; then
    kill "$pid"
    echo "Server stopped (PID $pid)."
  else
    echo "Server PID $pid not running. Cleaning up PID file."
    rm -f "$pid_file"
  fi
}

cmd_health() {
  local pid_file="$TASKS_DIR/.server-pid"
  if [ ! -f "$pid_file" ]; then
    echo "CRIT: No PID file found. Server is not running."
    exit 1
  fi

  local pid
  pid="$(cat "$pid_file")"
  if ! kill -0 "$pid" 2>/dev/null; then
    echo "CRIT: Server PID $pid is not running."
    exit 1
  fi

  echo "Server PID: $pid (alive)"
  echo "Dashboard:  http://localhost:4000"
  echo "Status:     OK"
}

cmd_send() {
  local role="$1"
  local message="$2"

  if [ -z "$role" ] || [ -z "$message" ]; then
    echo "Usage: company send <role> \"message\""
    exit 1
  fi

  # Find the current in-progress task for this role
  local task_file=""
  for f in "$TASKS_DIR"/*.md; do
    [ -f "$f" ] || continue
    local to status
    to="$(get_field "$f" "to")"
    status="$(get_field "$f" "status")"
    if [ "$to" = "$role" ] && [ "$status" = "in_progress" ]; then
      task_file="$f"
      break
    fi
  done

  if [ -z "$task_file" ]; then
    echo "No in-progress task found for role '$role'."
    exit 1
  fi

  # Append human input section to task file (triggers chokidar watcher)
  printf "\n\n## Human Input\n\n%s\n" "$message" >> "$task_file"
  echo "Message sent to $role via $(basename "$task_file")"
}

cmd_status() {
  printf "%-12s %-10s %-10s %-10s\n" "ROLE" "PENDING" "PROGRESS" "DONE"
  printf "%-12s %-10s %-10s %-10s\n" "----" "-------" "--------" "----"
  local roles_dir="$PROJECT_DIR/roles"
  for role_dir in "$roles_dir"/*/; do
    local role
    role="$(basename "$role_dir")"
    [[ "$role" == .* ]] && continue
    local pending=0 in_progress=0 done_count=0
    for f in "$TASKS_DIR"/*.md; do
      [ -f "$f" ] || continue
      local to status
      to="$(get_field "$f" "to")"
      status="$(get_field "$f" "status")"
      if [ "$to" = "$role" ]; then
        case "$status" in
          pending)     pending=$((pending + 1)) ;;
          in_progress) in_progress=$((in_progress + 1)) ;;
          done)        done_count=$((done_count + 1)) ;;
        esac
      fi
    done
    printf "%-12s %-10s %-10s %-10s\n" "$role" "$pending" "$in_progress" "$done_count"
  done
}

cmd_tasks() {
  local filter_role="${1:-}"

  printf "%-6s %-35s %-10s %-10s %-10s %-12s\n" "ID" "TITLE" "FROM" "TO" "OWNER" "STATUS"
  printf "%-6s %-35s %-10s %-10s %-10s %-12s\n" "---" "-----" "----" "--" "-----" "------"

  for f in "$TASKS_DIR"/*.md; do
    [ -f "$f" ] || continue
    local id title from to owner status
    id="$(get_field "$f" "id")"
    title="$(get_field "$f" "title")"
    from="$(get_field "$f" "from")"
    to="$(get_field "$f" "to")"
    owner="$(get_field "$f" "owner")"
    status="$(get_field "$f" "status")"

    if [ -n "$filter_role" ]; then
      if [ "$to" != "$filter_role" ] && [ "$from" != "$filter_role" ] && [ "$owner" != "$filter_role" ]; then
        continue
      fi
    fi

    printf "%-6s %-35s %-10s %-10s %-10s %-12s\n" \
      "${id:--}" "${title:--}" "${from:--}" "${to:--}" "${owner:--}" "${status:--}"
  done
}

cmd_next_id() {
  local max=0
  for f in "$TASKS_DIR"/*.md; do
    [ -f "$f" ] || continue
    local id
    id="$(get_field "$f" "id")"
    if [ -n "$id" ]; then
      local num
      num=$((10#$id))
      if [ "$num" -gt "$max" ]; then
        max=$num
      fi
    fi
  done
  printf "%03d\n" $((max + 1))
}

cmd_create() {
  local to_role="$1"
  local title="$2"

  # Validate role by checking if roles/<to_role> directory exists
  if [ ! -d "$PROJECT_DIR/roles/$to_role" ]; then
    echo "Error: Unknown role '$to_role'. No directory found at roles/$to_role"
    exit 1
  fi

  local next_id
  next_id="$(cmd_next_id)"

  local slug
  slug="$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g; s/--*/-/g; s/^-//; s/-$//' | cut -c1-50)"

  local filename="${next_id}-${slug}.md"
  local filepath="$TASKS_DIR/$filename"
  local today
  today="$(date '+%Y-%m-%d')"

  cat > "$filepath" <<EOF_TASK
---
id: "$next_id"
parent: null
from: human
to: $to_role
owner:
status: pending
priority: medium
created: $today
updated: $today
title: "$title"
---

## Objective

$title

## Details

(Add details here)
EOF_TASK

  echo "Created: tasks/$filename"
}

# Main dispatch
command="${1:-}"
shift || true

case "$command" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  health)  cmd_health ;;
  status)  cmd_status ;;
  tasks)   cmd_tasks "$@" ;;
  next-id) cmd_next_id ;;
  create)  cmd_create "$@" ;;
  send)    cmd_send "$@" ;;
  *)       usage ;;
esac
